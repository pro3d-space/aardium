{
  "name": "pro3d-viewer",
  "productName": "PRo3D Viewer",
  "desktopName": "space.pro3d.app.desktop",
  "version": "5.9.0-prerelease1",
  "description": "PRo3D, short for Planetary Robotics 3D Viewer, is an interactive 3D visualization tool to allow planetary scientists to work with high-resolution 3D reconstructions of the Martian surface.",
  "license": "AGPL",
  "copyright": "VRVis Zentrum für Virtual Reality und Visualisierung Forschungs-GmbH",
  "author": {
    "name": "The PRo3D Team",
    "url": "https://pro3d.space/"
  },
  "scripts": {
    "postinstall": "electron-rebuild node-shared-mem",
    "build": "electron-builder",
    "publish": "electron-builder --publish always",
    "signbuild": "bash ./scripts/signbuild.sh"
  },
  "main": "main.js",
  "repository": "https://github.com/pro3d-space/PRo3D",
  "dependencies": {
    "@electron/remote": "^2.1.0",
    "electron-localshortcut": "^3.2.1",
    "node-getopt": "^0.3.2",
    "node-shared-mem": "^2.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "dotenv": "^17.4.2",
    "electron": "42.3.0",
    "@electron/notarize": "^3.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "space.pro3d.app",
    "buildVersion": "${version}",
    "artifactName": "PRo3D.Viewer-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "**/*",
      "!scripts${/*}"
    ],
    "extraFiles": [
      "build/dotnet"
    ],
    "extraResources": [
      "build/icon.*"
    ],
    "win": {
      "icon": "icon.ico",
      "target": ["nsis", "zip"]
    },
    "nsis": {
      "artifactName": "PRo3D.Viewer-${version}-${os}-${arch}-Setup.${ext}",
      "installerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "deleteAppDataOnUninstall": true,
      "differentialPackage": false
    },
    "mac": {
      "icon": "icon.icns",
      "target": ["dmg", "zip"],
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "notarize": true
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "icon": "icon.png",
      "target": ["AppImage", "zip"],
      "syncDesktopName": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pro3d-space",
        "repo": "PRo3D",
        "releaseType": "draft",
        "publishAutoUpdate": false
      }
    ],
    "fileAssociations": [
      {
        "name": "PRo3D scene",
        "description": "PRo3D scene which references OPC data",
        "ext": "pro3d"
      }
    ],
    "buildDependenciesFromSource": true
  },
  "allowScripts": {
    "node-shared-mem": true,
    "electron-winstaller": true
  }
}
